stdout=serial
bootargs=console=ttySTM0,115200 debug ignore_loglevel earlycon root=PARTUUID=69DAD710-2CE4-4E3C-B16C-21A1D49ABED3 rw rootwait
bootcmd=setenv dfu_alt_info "boot part 0 4" ;\
        dfu 0 mmc 0 ;\
        load mmc 0:4 0xC0200000 /zImage ;\
	load mmc 0:4 0xC2400000 /stm32mp135d-odyssey-mx.dtb ;\
	bootz 0xC0200000 - 0xC2400000
